{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run build --filter='./packages/*' && turbo run dev",
    "dev:packages": "turbo run dev --filter='./packages/*'",
    "dev:web": "turbo run build --filter='./packages/*' && cd apps/web && yarn dev",
    "dev:native": "turbo run build --filter='./packages/*' && cd apps/native && yarn dev",
    "build": "./node_modules/.bin/turbo run build",
    "clean": "./node_modules/.bin/turbo run clean && rm -rf node_modules",
    "format": "./node_modules/.bin/prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "./node_modules/.bin/prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "lint": "eslint \"**/*.{ts,tsx,js,jsx}\" --ignore-path .gitignore",
    "lint:fix": "eslint \"**/*.{ts,tsx,js,jsx}\" --ignore-path .gitignore --fix",
    "lint:web": "cd apps/web && yarn lint",
    "lint:native": "cd apps/native && yarn lint",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.1",
    "turbo": "^2.9.5",
    "redux": "^4.2.1",
    "typescript": "^5.9.2",
    "react-redux": "^8.1.3"
  },
  "packageManager": "yarn@1.22.19",
  "engines": {
    "node": ">=18"
  },
  "name": "with-react-native-web"
}

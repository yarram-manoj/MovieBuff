{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run build --filter='./packages/*' && turbo run dev",
    "dev:packages": "turbo run dev --filter='./packages/*'",
    "dev:web": "turbo run build --filter='./packages/*' && cd apps/web && yarn dev",
    "dev:native": "turbo run build --filter='./packages/*' && cd apps/native && yarn dev",
    "build": "./node_modules/.bin/turbo run build",
    "clean": "./node_modules/.bin/turbo run clean && rm -rf node_modules",
    "format": "./node_modules/.bin/prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.7",
    "axios": "^1.6.2",
    "react-redux": "^8.1.3"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "turbo": "^2.9.5",
    "redux": "^4.2.1"
  },
  "packageManager": "yarn@1.22.19",
  "engines": {
    "node": ">=18"
  },
  "name": "with-react-native-web"
}
